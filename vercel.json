{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Frame-Options": "SAMEORIGIN",
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
      },
      "continue": true
    },
    {
      "src": "/periodic-table/(.*)",
      "dest": "https://periodic-table-of-cognitive-element.vercel.app/$1",
      "check": true
    },
    {
      "src": "/periodic-table",
      "dest": "https://periodic-table-of-cognitive-element.vercel.app/",
      "check": true
    },
    {
      "src": "/heuristics-playground/(.*)",
      "dest": "https://yl-app-heuristics-playground.vercel.app/$1",
      "check": true
    },
    {
      "src": "/heuristics-playground",
      "dest": "https://yl-app-heuristics-playground.vercel.app/",
      "check": true
    },
    {
